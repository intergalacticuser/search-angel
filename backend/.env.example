# Search Angel Configuration
# Copy to .env and fill in required values

# Application
SEARCH_ANGEL_APP_NAME=Search Angel
SEARCH_ANGEL_DEBUG=true
SEARCH_ANGEL_ENVIRONMENT=development
SEARCH_ANGEL_LOG_LEVEL=INFO

# PostgreSQL
SEARCH_ANGEL_PG_HOST=localhost
SEARCH_ANGEL_PG_PORT=5432
SEARCH_ANGEL_PG_USER=search_angel
SEARCH_ANGEL_PG_PASSWORD=changeme_pg_password
SEARCH_ANGEL_PG_DATABASE=search_angel

# OpenSearch
SEARCH_ANGEL_OS_HOST=localhost
SEARCH_ANGEL_OS_PORT=9200
SEARCH_ANGEL_OS_SCHEME=https
SEARCH_ANGEL_OS_USER=admin
SEARCH_ANGEL_OS_PASSWORD=YOUR_OS_PASSWORD
SEARCH_ANGEL_OS_VERIFY_CERTS=false
SEARCH_ANGEL_OS_INDEX_NAME=search_angel_documents

# Embeddings
SEARCH_ANGEL_EMBEDDING_MODEL=all-MiniLM-L6-v2
SEARCH_ANGEL_EMBEDDING_DIMENSION=384

# Search Defaults
SEARCH_ANGEL_SEARCH_DEFAULT_LIMIT=10
SEARCH_ANGEL_SEARCH_MAX_LIMIT=100
SEARCH_ANGEL_RRF_K=60

# Privacy
SEARCH_ANGEL_SESSION_TTL_MINUTES=30
SEARCH_ANGEL_IP_SALT_ROTATION_HOURS=24

# AI Summary (optional)
SEARCH_ANGEL_LLM_PROVIDER=openai
SEARCH_ANGEL_LLM_API_KEY=
SEARCH_ANGEL_LLM_MODEL=gpt-4o-mini
SEARCH_ANGEL_LLM_MAX_TOKENS=500

# Ingestion API Key (SHA-256 hash of the actual key)
SEARCH_ANGEL_INGESTION_API_KEY_HASH=

# Docker Compose variables
PG_PASSWORD=changeme_pg_password
OS_PASSWORD=YOUR_OS_PASSWORD
